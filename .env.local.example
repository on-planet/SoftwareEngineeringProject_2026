# Core services
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/quantpulse
REDIS_URL=redis://localhost:6379/0

# Snowball / Xueqiu cookie
XUEQIUTOKEN=xq_a_token=your_token_here;u=your_uid_here
# SNOWBALL_TOKEN=xq_a_token=your_token_here;u=your_uid_here

# Auth
AUTH_TOKEN_SECRET=replace_with_a_random_secret
AUTH_TOKEN_EXPIRE_HOURS=24
AUTH_ADMIN_ACCOUNT=admin
AUTH_ADMIN_PASSWORD=admin

# Optional LLM integration
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=20

# Optional SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
